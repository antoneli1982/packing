+let viradaModo=false;
+function dentroJanelaVirada(){ const h=new Date().getHours(); return h>=0 && h<2; }   // 00:00–01:59
+function ontem(){
+  const d=new Date(); d.setDate(d.getDate()-1);
+  return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");
+}
+function viradaInicioValido(hi){
+  if(!hi) return false;
+  const[a,b]=hi.split(":").map(Number);
+  return (a*60+b) >= 23*60;                                          // a partir das 23:00
+}
+function cruzaMeiaNoite(hi,hf){
+  if(!hi||!hf) return false;
+  const[a,b]=hi.split(":").map(Number),[c,d]=hf.split(":").map(Number);
+  return (c*60+d) < (a*60+b);                                        // fim numericamente antes do início ⇒ cruzou 00:00
+}
+function proximoDia(s){
+  const d=new Date(s+"T12:00:00"); d.setDate(d.getDate()+1);
